rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard primary helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation & Resource Rules
    function isValidUserProfile(data) {
      return data.uid is string &&
             data.uid.size() <= 128 &&
             data.email is string &&
             data.email.size() <= 200 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 150)) &&
             (!('voiceSettings' in data) || data.voiceSettings is map) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 100)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('handle' in data) || (data.handle is string && data.handle.size() <= 100)) &&
             (!('hiddenPreferences' in data) || data.hiddenPreferences is map);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().uid == existing().uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'voiceSettings', 'hiddenPreferences', 'bio', 'handle'])
      );
      allow delete: if false; // Profiles are permanent once signed up for creators
      
      // Library subcollection checks
      match /library/{itemId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLibraryItem(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isOwner(userId) && isValidLibraryItem(incoming()) && incoming().userId == existing().userId && (
          incoming().diff(existing()).affectedKeys().hasOnly(['isFavorite', 'prompt', 'mood', 'duration', 'contentType', 'language', 'data', 'timestamp'])
        );
        allow delete: if isOwner(userId);
      }
    }

    // Helper to validate entire LibraryItem shape on write
    function isValidLibraryItem(data) {
      return data.id is string &&
             data.id.size() <= 128 &&
             data.userId is string &&
             data.userId.size() <= 128 &&
             data.prompt is string &&
             data.prompt.size() <= 1000 &&
             data.data is map &&
             (!('mood' in data) || (data.mood is string && data.mood.size() <= 100)) &&
             (!('timestamp' in data) || (data.timestamp is string && data.timestamp.size() <= 100)) &&
             (!('duration' in data) || (data.duration is string && data.duration.size() <= 100)) &&
             (!('contentType' in data) || (data.contentType is string && data.contentType.size() <= 100)) &&
             (!('language' in data) || (data.language is string && data.language.size() <= 100)) &&
             (!('isFavorite' in data) || data.isFavorite is bool);
    }
  }
}
